# Twilio — use credentials from ONE account. Redeploy API after changes.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
# Prefer a Messaging Service SID (starts with MG) from the same account as SID/token:
TWILIO_MESSAGING_SERVICE_SID=
# Or send from a Twilio phone number (+E.164) if you are not using a Messaging Service:
# TWILIO_PHONE_NUMBER=
# Optional WhatsApp sender (whatsapp:+... or approved sandbox):
# TWILIO_WHATSAPP_FROM=

# Public invite links in SMS (no trailing slash):
# FRONTEND_URL=https://your-admin-app.vercel.app
